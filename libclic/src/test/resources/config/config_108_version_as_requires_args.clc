# When version information is invoked, will print "Copyright (C) Some Company 2021; licensed under the MIT license."

global.version.name=version
global.version.text=Copyright (C) Some Company 2021; licensed under the MIT license.

# 
# The name must:
#   - match the option.[name] option configuration. For example, if 
#     global.version.name is defined as 'version' (not including apostrophes), 
#     then there must also be an option definition named 'option.version';
#   - option.[name] hasArg must be false;
#   - option.[name] must have a description
# 
# Defining this will print the version information then quit with 0
# status.
# 

option.version.opts=version
option.version.hasArg=false
option.version.ignoreCliArgs=false
option.version.description=Print version information then quit.

args.definitely-required.length=1
args.definitely-required.optional=false