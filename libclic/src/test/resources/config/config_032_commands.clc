global.help.option.name=showHelp

global.help.command.usage=reporttool [command] [options]

global.help.command.header=Supported commands are import and export. Try \
    \n  reporttool [command] -h\
    \nor\
    \n  reporttool [command] --help\
    \nfor individual help options.\n

global.help.command.footer=Copyright www.statefive.org

command.name=import
command.usage=Import reports between the specified dates. \
    Both dates must be specified.

option.dateFrom.opts=f/from
option.dateFrom.hasArg=true
option.dateFrom.argName=date
option.dateFrom.description=Start date to import the reports for.

option.dateTo.opts=t/to
option.dateTo.hasArg=true
option.dateTo.argName=date
option.dateTo.description=End date to import the reports for.

option.showHelp.opts=h/help
option.showHelp.hasArg=false
option.showHelp.description=Show this help then quit.

command.name=export
command.usage=Export reports in the specified format to the \
    given directory.

option.format.opts=f/format
option.format.hasArg=true
option.format.argName=format
option.format.description=Format to export data to.

option.dir.opts=d/directory
option.dir.hasArg=true
option.dir.argName=dir
option.dir.description=Directory to export the reports to.

option.showHelp.opts=h/help
option.showHelp.hasArg=false
option.showHelp.description=Show this help then quit.